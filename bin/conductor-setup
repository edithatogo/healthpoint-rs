#!/usr/bin/env bash
set -Eeuo pipefail

# Link secrets/config from a Conductor root outside worktrees when available.
if [[ -n "${CONDUCTOR_ROOT_PATH:-}" && -f "$CONDUCTOR_ROOT_PATH/.env" ]]; then
  ln -sf "$CONDUCTOR_ROOT_PATH/.env" .env
fi

scripts/static-preflight.py
scripts/generate-contract-schemas.py

if ! command -v cargo >/dev/null 2>&1; then
  if [[ "${CONDUCTOR_ALLOW_NO_CARGO:-}" == "1" ]]; then
    echo "Rust/Cargo not found; metadata-only Conductor setup completed because CONDUCTOR_ALLOW_NO_CARGO=1." >&2
    exit 0
  fi
  echo "Rust/Cargo is required for full setup. Install via rustup, or set CONDUCTOR_ALLOW_NO_CARGO=1 for metadata-only setup." >&2
  exit 1
fi

cargo fetch
cargo check --workspace --all-targets
