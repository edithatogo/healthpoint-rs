#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPORT_DIR="${MCP_VALIDATION_REPORT_DIR:-$ROOT/target/mcp-validation}"
REPORT_PATH="${MCP_VALIDATION_REPORT_PATH:-$REPORT_DIR/healthpoint-mcp-validation.json}"
MODE="${1:-fast}"
shift || true

mkdir -p "$REPORT_DIR"

VALIDATOR_BIN="${MCP_VALIDATE_BIN:-}"
if [[ -z "$VALIDATOR_BIN" && -x "$ROOT/target/mcp-validation-venv313/bin/mcp-validate" ]]; then
  VALIDATOR_BIN="$ROOT/target/mcp-validation-venv313/bin/mcp-validate"
fi
if [[ -z "$VALIDATOR_BIN" ]]; then
  VALIDATOR_BIN="$(command -v mcp-validate || true)"
fi

if [[ -z "$VALIDATOR_BIN" ]]; then
  cat >&2 <<'MSG'
mcp-validate is not installed.
Install the preferred CLI validator with:
  python3.13 -m pip install git+https://github.com/RHEcosystemAppEng/mcp-validation.git
MSG
  exit 127
fi

SCAN_FLAG="--skip-mcp-scan"
if [[ "$MODE" == "full" ]]; then
  SCAN_FLAG=""
elif [[ "$MODE" != "fast" ]]; then
  echo "usage: scripts/validate-mcp-server [fast|full] [-- extra mcp-validate args]" >&2
  exit 2
fi

export HEALTHPOINT_MODE="${HEALTHPOINT_MODE:-synthetic}"
export HEALTHPOINT_API_KEY="${HEALTHPOINT_API_KEY:-}"
export HEALTHPOINT_BASE_URL="${HEALTHPOINT_BASE_URL:-https://uat.healthpointapi.com/baseR4/}"
export HEALTHPOINT_AUTH_SCHEME="${HEALTHPOINT_AUTH_SCHEME:-none}"
export HEALTHPOINT_GEO_SEARCH_MODE="${HEALTHPOINT_GEO_SEARCH_MODE:-healthpoint-lat-lon}"
export HEALTHPOINT_TIMEOUT_SECS="${HEALTHPOINT_TIMEOUT_SECS:-5}"

# shellcheck disable=SC2086
"$VALIDATOR_BIN" \
  --json-report "$REPORT_PATH" \
  --repo-url "https://github.com/edithatogo/healthpoint-rs" \
  $SCAN_FLAG \
  "$@" \
  -- cargo run -p healthpoint-mcp

echo "$REPORT_PATH"
