{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.edithatogo/healthpoint-rs",
  "title": "healthpoint-rs",
  "description": "Read-only MCP server for Healthpoint HL7 FHIR directory lookup with synthetic default mode and BYO-key live mode.",
  "repository": {
    "url": "https://github.com/edithatogo/healthpoint-rs",
    "source": "github"
  },
  "websiteUrl": "https://github.com/edithatogo/healthpoint-rs",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/edithatogo/healthpoint-rs/main/assets/healthpoint-rs-icon.svg",
      "mimeType": "image/svg+xml",
      "sizes": [
        "any"
      ]
    }
  ],
  "version": "0.1.0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/edithatogo/healthpoint-rs",
  "keywords": [
    "healthpoint",
    "fhir",
    "mcp",
    "snomed",
    "healthcare"
  ],
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/edithatogo/healthpoint-mcp:0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "HEALTHPOINT_MODE",
          "description": "Runtime mode: synthetic uses bundled fixture data without credentials; live uses the licensed Healthpoint API.",
          "isRequired": false,
          "format": "string",
          "default": "synthetic"
        },
        {
          "name": "HEALTHPOINT_API_KEY",
          "description": "Optional user-provided licensed Healthpoint API key/token. Required only when HEALTHPOINT_MODE=live.",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "HEALTHPOINT_BASE_URL",
          "description": "Healthpoint API base URL.",
          "isRequired": false,
          "format": "string",
          "default": "https://uat.healthpointapi.com/baseR4/"
        },
        {
          "name": "HEALTHPOINT_AUTH_SCHEME",
          "description": "bearer | x-api-key | header:<name> | none",
          "isRequired": false,
          "format": "string",
          "default": "x-api-key"
        },
        {
          "name": "HEALTHPOINT_GEO_SEARCH_MODE",
          "description": "healthpoint-lat-lon | fhir-near",
          "isRequired": false,
          "format": "string",
          "default": "healthpoint-lat-lon"
        },
        {
          "name": "HEALTHPOINT_TIMEOUT_SECS",
          "description": "HTTP timeout in seconds, clamped to 1..300.",
          "isRequired": false,
          "format": "string",
          "default": "30"
        }
      ]
    }
  ]
}
