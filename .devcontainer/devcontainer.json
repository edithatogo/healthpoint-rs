{
  "name": "healthpoint-rs",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "target": "dev"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb"
      ]
    }
  },
  "postCreateCommand": "cargo check --workspace --all-targets",
  "remoteEnv": {
    "RUST_LOG": "info,healthpoint=debug"
  }
}
