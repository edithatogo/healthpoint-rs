# Required for live Healthpoint API use. Never commit .env.
HEALTHPOINT_API_KEY=

# Verified UAT FHIR base URL. Replace only if Healthpoint provides a different licensed endpoint.
HEALTHPOINT_BASE_URL=https://uat.healthpointapi.com/baseR4/

# bearer | x-api-key | header:<name> | none
HEALTHPOINT_AUTH_SCHEME=x-api-key

# local-only | licensed-share | open-approved
HEALTHPOINT_EXPORT_POLICY=local-only

# Optional: JSON logs are useful for MCP/debug sessions.
RUST_LOG=info,healthpoint=debug

# healthpoint-lat-lon | fhir-near
HEALTHPOINT_GEO_SEARCH_MODE=healthpoint-lat-lon

# Clamped to 1..300 seconds.
HEALTHPOINT_TIMEOUT_SECS=30
