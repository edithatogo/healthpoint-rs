# Required for live Healthpoint API use. Never commit .env.
HEALTHPOINT_API_KEY=

# Public landing page; replace with the licensed API base URL if Healthpoint provides a tenant/UAT/prod endpoint.
HEALTHPOINT_BASE_URL=https://www.healthpointapi.com/

# bearer | x-api-key | header:<name> | none
HEALTHPOINT_AUTH_SCHEME=bearer

# local-only | licensed-share | open-approved
HEALTHPOINT_EXPORT_POLICY=local-only

# Optional: JSON logs are useful for MCP/debug sessions.
RUST_LOG=info,healthpoint=debug
